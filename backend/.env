# Database
# For development without PostgreSQL, use SQLite:
DATABASE_URL=sqlite:///./cognitive_learning.db
# For production with PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/cognitive_learning
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis (optional for initial testing)
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=crzCSLrst4_PfjlrdOLN6KPJZcCNhLqmiZyU39DDa-A
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Application
APP_NAME=Cognitive Learning Platform
APP_VERSION=1.0.0
DEBUG=True

# ML Models
MODEL_PATH=app/ml/models
MODEL_UPDATE_INTERVAL=86400

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2